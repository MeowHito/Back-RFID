# Backend Environment Variables
# Copy this file to .env and update with your values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rfid-timing

# Server Port
PORT=3001

# Environment
NODE_ENV=development

# JWT Secret - IMPORTANT: Generate a strong random secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://front-rfid.vercel.app

# RaceTiger (China timing) integration
RACE_TIGER_BASE_URL=https://rqs.racetigertiming.com
RACE_TIGER_INFO_PATH=/Dif/info
RACE_TIGER_BIO_PATH=/Dif/bio
RACE_TIGER_SPLIT_PATH=/Dif/splitScore
RACE_TIGER_PARTNER_CODE=000001
RACE_TIGER_TIMEOUT_MS=15000

# ========== CCTV Beta (Larix → MediaMTX → S3) ==========
# EC2 ingest host (รัน MediaMTX). ใช้สร้าง SRT/RTMP/HLS URL
CCTV_BETA_INGEST_HOST=ingest.your-domain.com
CCTV_BETA_PLAYBACK_HOST=play.your-domain.com
# Shared HMAC secret — ต้องตรงกับ MTX_INGEST_SECRET บน EC2
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CCTV_BETA_INGEST_SECRET=change-me-32-byte-hex
