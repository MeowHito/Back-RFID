# Copy to /opt/cctv-beta/.env on the EC2 ingest host and fill in real values.
# chmod 600 .env

# === MUST match backend/.env CCTV_BETA_INGEST_SECRET ===
CCTV_BETA_INGEST_SECRET=replace-with-32-byte-hex-from-backend-env
MTX_INGEST_SECRET=replace-with-32-byte-hex-from-backend-env

# URL where MediaMTX hooks will POST back (must be reachable from EC2)
BACKEND_URL=https://api.your-domain.com

# === AWS S3 ===
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=ap-southeast-1
S3_BUCKET=cctv-rfid

# === Disk cleanup (cleanup container) ===
# Files in /var/cctv/hls older than this many minutes are deleted to reclaim
# EC2 disk space. They are already on S3 (s3-sync runs every 15s) — IF sync is
# actually working. cleanup does NOT verify upload success, so a stalled sync
# silently destroys recordings (this happened in 2026-05 when --acl public-read
# was blocked by Bucket owner enforced). Default 1440 = 24h grace window.
BETA_CLEANUP_AGE_MIN=1440
# How often the cleanup loop scans (seconds).
BETA_CLEANUP_INTERVAL_SEC=300
